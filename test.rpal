// Test Program
// Comprehensive RPAL Test Program - Corrected
let
  logic_test = (true & false) or (not (10 ls 5))
  and
  arith_test = 2 ** 3 + 16 / 2 - 1
  and
  string_test = 'Hello\n\tRPAL'
within
  rec factorial n = n eq 0 -> 1 | n * factorial (n - 1)
  and
  my_list = 10 aug 20 aug 30 aug nil
within
  rec sum_list L = (L eq nil) -> 0 | (L 1) + sum_list (L 2) 
in
  Print (
    factorial 5,
    sum_list my_list,
    logic_test,
    arith_test,
    string_test
  )
