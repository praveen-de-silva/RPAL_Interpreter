# RPAL IDE Server Configuration

# Environment: development | staging | production
RPAL_ENV=production

# Server
RPAL_IDE_HOST=0.0.0.0
RPAL_IDE_PORT=8787

# SSL/TLS Configuration
RPAL_USE_SSL=false
RPAL_SSL_CERT=/etc/ssl/certs/rpal_cert.pem
RPAL_SSL_KEY=/etc/ssl/private/rpal_key.pem

# Security
RPAL_TIMEOUT=30
RPAL_MAX_CODE_SIZE=100
RPAL_ALLOWED_ORIGINS=localhost,127.0.0.1

# Debug (development only)
RPAL_IDE_DEBUG=false

