let rec makeTup T1 i T2 j T =
    i le (Order T1) & j le (Order T2)
    -> (T1 i) le (T2 j)
        -> makeTup T1 (i+1) T2 j (T aug (T1 i))
        | makeTup T1 i T2 (j+1) (T aug (T2 j))
    | i le (Order T1) or j le (Order T2)
        -> i le (Order T1)
            -> makeTup T1 (i+1) T2 j (T aug (T1 i))
            | makeTup T1 i T2 (j+1) (T aug (T2 j))
        | T

in Print (makeTup (1,2,3) 1 (4,5,6) 1 nil)